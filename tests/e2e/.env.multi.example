# E2E Test Configuration - Multi-Auth (ISP + PVWA simultaneously)
# Copy to .env and fill in values for both ISP and PVWA.
#
# With both profiles configured, all tests run regardless of auth requirement.
# Services pick the authenticator they need from the full set.

# --- Auth Expect Filter ---
# Controls which authenticators are built. Default: all
# Values: all, isp, pvwa, isp,pvwa
# When set to a specific list, missing credentials are a hard error (not a skip).
# IDSEC_E2E_AUTH_EXPECT=all

# --- ISP Auth Profile ---
IDSEC_E2E_ISP_AUTH_METHOD=identity_service_user  # or: identity
IDSEC_E2E_ISP_USERNAME=serviceuser@tenant.cyberark.cloud.12345
IDSEC_E2E_ISP_SECRET=your_isp_secret
# IDSEC_E2E_ISP_IDENTITY_URL=
# IDSEC_E2E_ISP_IDENTITY_TENANT_SUBDOMAIN=

# --- PVWA Auth Profile ---
IDSEC_E2E_PVWA_USERNAME=your_pvwa_username
IDSEC_E2E_PVWA_SECRET=your_pvwa_password
IDSEC_E2E_PVWA_URL=https://pvwa.example.com
IDSEC_E2E_PVWA_LOGIN_METHOD=ldap  # cyberark, ldap, or windows

# --- General ---
# IDSEC_E2E_SKIP=false
