# PVWA E2E Test Configuration
# Copy to .env and fill in values.
#
# NOTE: The framework now supports multi-auth profiles. You can configure
# both ISP and PVWA simultaneously using per-provider env vars.
# See .env.multi.example for a combined ISP+PVWA configuration.
#
# Old-style vars (IDSEC_E2E_USERNAME, IDSEC_E2E_SECRET, IDSEC_E2E_AUTH_METHOD)
# are still supported for backward compatibility but deprecated.

# --- Auth Expect Filter ---
# Controls which authenticators are built. Default: all
# Values: all, isp, pvwa, isp,pvwa
# IDSEC_E2E_AUTH_EXPECT=pvwa

# --- PVWA Auth Profile (new-style, recommended) ---
IDSEC_E2E_PVWA_USERNAME=your_pvwa_username
IDSEC_E2E_PVWA_SECRET=your_pvwa_password
IDSEC_E2E_PVWA_URL=https://pvwa.example.com
IDSEC_E2E_PVWA_LOGIN_METHOD=ldap  # cyberark, ldap, or windows

# --- General ---
# IDSEC_E2E_SKIP=false

# --- Backward Compat (deprecated, use PVWA-prefixed vars above) ---
# IDSEC_E2E_AUTH_METHOD=pvwa
# IDSEC_E2E_USERNAME=your_pvwa_username
# IDSEC_E2E_SECRET=your_pvwa_password
