# E2E Test Configuration - ISP Only
# Copy to .env and fill in values.
#
# NOTE: The framework now supports multi-auth profiles. You can configure
# both ISP and PVWA simultaneously using per-provider env vars below.
# See .env.multi.example for a combined ISP+PVWA configuration.
#
# Old-style vars (IDSEC_E2E_USERNAME, IDSEC_E2E_SECRET, IDSEC_E2E_AUTH_METHOD)
# are still supported for backward compatibility but deprecated.

# --- Auth Expect Filter ---
# Controls which authenticators are built. Default: all
# Values: all, isp, pvwa, isp,pvwa
# IDSEC_E2E_AUTH_EXPECT=isp

# --- ISP Auth Profile (new-style, recommended) ---
IDSEC_E2E_ISP_AUTH_METHOD=identity_service_user  # or: identity
IDSEC_E2E_ISP_USERNAME=serviceuser@tenant.cyberark.cloud.12345
IDSEC_E2E_ISP_SECRET=your_secret

# Optional ISP overrides
# IDSEC_E2E_ISP_IDENTITY_URL=
# IDSEC_E2E_ISP_IDENTITY_TENANT_SUBDOMAIN=

# --- General ---
# IDSEC_E2E_SKIP=false

# --- Backward Compat (deprecated, use ISP-prefixed vars above) ---
# IDSEC_E2E_AUTH_METHOD=identity_service_user
# IDSEC_E2E_USERNAME=serviceuser@tenant.cyberark.cloud.12345
# IDSEC_E2E_SECRET=your_secret
